diff --git a/templates/sales/payroll_dashboard.html b/templates/sales/payroll_dashboard.html
new file mode 100644
index 0000000..4640c84
--- /dev/null
+++ b/templates/sales/payroll_dashboard.html
@@ -0,0 +1,160 @@
+{% extends "base.html" %}
+{% load static %}
+{% block title %}Payroll Forensics · MoneyShot{% endblock %}
+
+{% block content %}
+<div class="space-y-8">
+    <!-- Header -->
+    <div class="flex items-center justify-between">
+        <div>
+            <h1 class="text-3xl font-black text-white uppercase tracking-tighter">Payroll Forensics</h1>
+            <p class="text-gray-400 mt-1">"The Salary Squeeze": Manage internal employee debt settlements.</p>
+        </div>
+        <div class="flex items-center gap-4">
+            <div class="px-4 py-2 rounded-xl bg-primary-500/10 border border-primary-500/20">
+                <span class="text-[10px] font-bold text-primary-400 uppercase tracking-widest block">Active Links</span>
+                <span class="text-xl font-black text-white">{{ employees.count }}</span>
+            </div>
+        </div>
+    </div>
+
+    <!-- Employee Grid -->
+    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
+        {% for emp in employees %}
+        <div class="glass-card p-6 rounded-2xl border-white/5 hover:border-primary-500/30 transition-all group overflow-hidden relative">
+            <!-- Background Glow -->
+            <div class="absolute -right-4 -top-4 w-24 h-24 bg-primary-500/10 blur-3xl rounded-full group-hover:bg-primary-500/20 transition-all"></div>
+
+            <div class="relative z-10">
+                <div class="flex items-start justify-between mb-4">
+                    <div class="flex items-center gap-3">
+                        <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-gray-800 to-gray-900 border border-white/5 flex items-center justify-center text-primary-400">
+                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
+                        </div>
+                        <div>
+                            <h3 class="text-lg font-bold text-white">{{ emp.username }}</h3>
+                            <p class="text-xs text-gray-500 uppercase tracking-widest font-bold">{{ emp.get_role_display }}</p>
+                        </div>
+                    </div>
+                </div>
+
+                <div class="space-y-3 mb-6">
+                    <div class="flex justify-between items-center p-3 rounded-xl bg-white/5">
+                        <span class="text-xs text-gray-400">Monthly Salary</span>
+                        <span class="font-bold text-white">₱{{ emp.monthly_salary|default:0|stringformat:".2f" }}</span>
+                    </div>
+                    <div class="flex justify-between items-center p-3 rounded-xl {% if emp.linked_customer.outstanding_balance > 0 %}bg-red-500/10 border border-red-500/20{% else %}bg-emerald-500/10 border border-emerald-500/20{% endif %}">
+                        <span class="text-sm font-bold {% if emp.linked_customer.outstanding_balance > 0 %}text-red-400{% else %}text-emerald-400{% endif %}">Current Debt</span>
+                        <span class="text-lg font-black {% if emp.linked_customer.outstanding_balance > 0 %}text-red-400{% else %}text-emerald-400{% endif %}">₱{{ emp.linked_customer.outstanding_balance|stringformat:".2f" }}</span>
+                    </div>
+                </div>
+
+                {% if emp.linked_customer.outstanding_balance > 0 %}
+                <button onclick="settleDebt({{ emp.id }}, '{{ emp.username }}', {{ emp.linked_customer.outstanding_balance }})"
+                    class="w-full py-3 rounded-xl bg-gradient-to-r from-primary-600 to-primary-700 hover:from-primary-500 hover:to-primary-600 text-white font-black uppercase tracking-widest text-xs transition-all shadow-lg shadow-primary-500/20">
+                    Apply Salary Squeeze
+                </button>
+                {% else %}
+                <button disabled class="w-full py-3 rounded-xl bg-gray-800 text-gray-500 font-bold uppercase tracking-widest text-xs cursor-not-allowed">
+                    Debt Free
+                </button>
+                {% endif %}
+            </div>
+        </div>
+        {% empty %}
+        <div class="col-span-full py-20 text-center">
+            <div class="w-20 h-20 bg-gray-800/50 rounded-3xl flex items-center justify-center mx-auto mb-4 border border-white/5">
+                <svg class="w-10 h-10 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
+            </div>
+            <h2 class="text-xl font-bold text-white">No Linked Employees</h2>
+            <p class="text-gray-500 mt-2">Link employee accounts to customer profiles to enable the Salary Squeeze.</p>
+        </div>
+        {% endfor %}
+    </div>
+</div>
+
+<!-- Squeeze Confirmation Modal -->
+<div id="squeeze-modal" class="hidden fixed inset-0 z-[100] items-center justify-center bg-slate-950/90 backdrop-blur-2xl">
+    <div class="glass-card p-8 rounded-3xl max-w-md w-full mx-4 space-y-6 border-primary-500/20 shadow-2xl shadow-primary-500/10">
+        <div class="text-center">
+            <div class="w-16 h-16 bg-red-500/20 rounded-2xl flex items-center justify-center mx-auto mb-4 border border-red-500/30">
+                <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
+            </div>
+            <h2 class="text-2xl font-black text-white uppercase tracking-tight">Confirm Salary Squeeze</h2>
+            <p class="text-gray-400 mt-2 text-sm">You are about to settle internal debt by deducting from payroll.</p>
+        </div>
+
+        <div class="p-4 rounded-2xl bg-surface-900 border border-gray-800 space-y-2">
+            <div class="flex justify-between text-xs font-bold text-gray-500 tracking-widest uppercase">
+                <span>Employee</span>
+                <span id="modal-employee" class="text-white">---</span>
+            </div>
+            <div class="flex justify-between text-xs font-bold text-gray-500 tracking-widest uppercase">
+                <span>Total Squeeze</span>
+                <span id="modal-amount" class="text-red-400">₱0.00</span>
+            </div>
+        </div>
+
+        <div class="flex gap-3">
+            <button onclick="closeModal()" class="flex-1 py-4 rounded-2xl bg-surface-800 hover:bg-surface-700 text-gray-400 font-bold uppercase tracking-widest text-xs transition-all">
+                Cancel
+            </button>
+            <button onclick="executeSqueeze()" id="modal-confirm-btn" class="flex-[2] py-4 rounded-2xl bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-500 hover:to-rose-500 text-white font-black uppercase tracking-widest shadow-xl shadow-red-500/20 transition-all">
+                Confirm Deduction
+            </button>
+        </div>
+    </div>
+</div>
+
+<script>
+let currentUserId = null;
+
+function settleDebt(userId, username, amount) {
+    currentUserId = userId;
+    document.getElementById('modal-employee').textContent = username;
+    document.getElementById('modal-amount').textContent = '₱' + amount.toLocaleString(undefined, {minimumFractionDigits: 2});
+    const modal = document.getElementById('squeeze-modal');
+    modal.classList.remove('hidden');
+    modal.classList.add('flex');
+}
+
+function closeModal() {
+    const modal = document.getElementById('squeeze-modal');
+    modal.classList.add('hidden');
+    modal.classList.remove('flex');
+    currentUserId = null;
+}
+
+function executeSqueeze() {
+    if (!currentUserId) return;
+
+    const btn = document.getElementById('modal-confirm-btn');
+    btn.disabled = true;
+    btn.textContent = 'Processing...';
+
+    fetch(`/sales/payroll/settle/${currentUserId}/`, {
+        method: 'POST',
+        headers: {
+            'X-CSRFToken': '{{ csrf_token }}',
+            'Content-Type': 'application/json'
+        }
+    })
+    .then(r => r.json())
+    .then(data => {
+        if (data.success) {
+            showToast('Success', data.message, 'success');
+            setTimeout(() => location.reload(), 1500);
+        } else {
+            showToast('Error', data.message, 'error');
+            btn.disabled = false;
+            btn.textContent = 'Confirm Deduction';
+        }
+    })
+    .catch(err => {
+        showToast('Error', 'Network error occurred.', 'error');
+        btn.disabled = false;
+        btn.textContent = 'Confirm Deduction';
+    });
+}
+</script>
+{% endblock %}
